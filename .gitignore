# Build outputs (Model Y: the wheel + attestation bundle are release
# assets regenerated by `agentos sign`, not source-controlled).
dist/
attestations/*
!attestations/.gitkeep

# Environments + caches
.venv/
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/

# uv.lock is committed: release evidence must resolve from the public tree.
